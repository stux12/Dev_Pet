{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DevPet",
  "version": "0.2.12",
  "identifier": "com.devpet.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DevPet",
        "width": 260,
        "height": 176,
        "resizable": false,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "center": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk3NjkzODRGMEQwMzIzMjAKUldRZ0l3TU5UemhwbDFNOEZGSXo3cEhXN0dSMkZ1Y0hsdnlsMVdaWUdIQ3EyQmc0UjBnaDlkVW4K",
      "endpoints": [
        "https://github.com/stux12/Dev_Pet/releases/latest/download/latest.json"
      ]
    }
  }
}
